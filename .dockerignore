# Keep local dev artifacts out of the image; the Dockerfile installs deps
# itself and a macOS-built node_modules contains the wrong platform's
# rollup binary (see Dockerfile comment about npm cli#4828).
**/node_modules/
**/dist/
**/.venv/
**/__pycache__/
**/.pytest_cache/
**/.ruff_cache/
**/.DS_Store
**/dump.rdb
.git/
.idea/
.vscode/
